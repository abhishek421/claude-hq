# Run `npm run setup` to generate these automatically.
# Or: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:you@example.com

# Root directory for the file browser (defaults to your home directory)
BASE_DIR=/Users/you

# Server port (default: 4242)
PORT=4242
